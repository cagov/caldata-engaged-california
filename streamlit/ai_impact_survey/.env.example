# Copy this file to .env and fill in your values for local development.
# .env is gitignored and should never be committed.

# Snowflake connection
SNOWFLAKE_ACCOUNT=VSB79059-HJB86910
SNOWFLAKE_USER=your.name@innovation.ca.gov
SNOWFLAKE_ROLE=TRANSFORMER_ENGCA_DEV
# Your default warehouse — check Snowsight or ask your Snowflake admin
SNOWFLAKE_WAREHOUSE=your_warehouse_name

# Snowflake Cortex LLM model names (availability varies by region).
# Common options: snowflake-arctic, mistral-7b, llama3.1-8b, llama3.1-70b, mistral-large2
LLM_MODEL_LOW=llama3.1-8b
LLM_MODEL_MED=claude-3-5-sonnet
LLM_MODEL_HIGH=claude-4-sonnet
